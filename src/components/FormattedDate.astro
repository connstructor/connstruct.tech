---
interface Props {
  date: Date;
}
const { date } = Astro.props;
const iso = date.toISOString().slice(0, 10);
// Frontmatter dates parse as UTC midnight; format in UTC too so the visible
// label matches the ISO datetime attribute regardless of the build machine's TZ.
const label = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<time datetime={iso}>{label}</time>
