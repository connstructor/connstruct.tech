---
import { NAV, HANDLE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

// Normalize the path so /blog and /blog/some-post both light up "blog".
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
function isActive(href: string) {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href + '/');
}
---

<header class="site-header">
  <div class="container bar">
    <a href="/" class="brand" aria-label="Home">
      <span class="brand-name">{HANDLE}</span><span class="brand-tail">:~</span><span
        class="brand-sym">$</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={['nav-link', { active: isActive(item.href) }]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 3.1rem;
    flex-wrap: wrap;
  }
  .brand {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text-bright);
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand-name {
    color: var(--text-bright);
  }
  .brand:hover .brand-name {
    color: var(--accent);
  }
  .brand-tail {
    color: var(--text-dim);
    margin-left: 0.1ch;
  }
  /* Match the canonical green prompt symbol used by .cmd / footer. */
  .brand-sym {
    color: var(--green);
  }
  .nav {
    display: flex;
    align-items: center;
    gap: clamp(0.6rem, 2.5vw, 1.25rem);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .nav-link {
    color: var(--text-dim);
    padding: 0.2rem 0;
    position: relative;
  }
  .nav-link:hover {
    color: var(--text-bright);
    text-decoration: none;
  }
  .nav-link.active {
    color: var(--text-bright);
  }
  /* Active marker: a small accent prompt caret. */
  .nav-link.active::before {
    content: '> ';
    color: var(--accent);
  }

  @media (max-width: 30rem) {
    .bar {
      min-height: 0;
      padding-block: 0.6rem;
    }
    .nav {
      width: 100%;
      gap: 0.9rem;
    }
    .nav .theme-toggle {
      margin-left: auto;
    }
  }
</style>
