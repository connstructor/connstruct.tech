---
import Layout from './Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  /** Estimated reading time in minutes. */
  readingMinutes: number;
}
const { post, readingMinutes } = Astro.props;
const { title, description, pubDate, updatedDate, tags = [] } = post.data;
---

<Layout title={title} description={description} type="article">
  <main id="main" class="container">
    <article>
      <a href="/blog" class="back mono">cd ../blog</a>

      <header class="post-head">
        <h1 class="post-title">{title}</h1>
        <p class="meta mono">
          <FormattedDate date={pubDate} />
          <span class="sep">·</span>
          <span>{readingMinutes} min read</span>
          {
            updatedDate && (
              <>
                <span class="sep">·</span>
                <span>updated <FormattedDate date={updatedDate} /></span>
              </>
            )
          }
        </p>
        {
          tags.length > 0 && (
            <ul class="tags mono" aria-label="tags">
              {tags.map((t) => (
                <li>#{t}</li>
              ))}
            </ul>
          )
        }
      </header>

      <div class="prose">
        <slot />
      </div>

      <footer class="post-foot">
        <a href="/blog" class="mono">← back to all posts</a>
      </footer>
    </article>
  </main>
</Layout>

<style>
  .back {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
  }
  .back::before {
    content: '$ ';
    color: var(--green);
  }
  .post-head {
    margin-bottom: 2.2rem;
    padding-bottom: 1.3rem;
    border-bottom: 1px solid var(--border);
  }
  /* Article headline — its own class so the shared .page-title (page headers,
     always 1.6rem) stays single-purpose and can't drift. Bigger + responsive
     on purpose: an article's main headline earns more size than a page header. */
  .post-title {
    font-size: clamp(1.5rem, 4.5vw, 1.85rem);
    margin-bottom: 0.7rem;
  }
  .meta {
    font-size: 0.82rem;
    color: var(--text-dim);
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5ch;
    align-items: center;
  }
  .sep {
    opacity: 0.6;
  }
  .tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    padding: 0;
    margin: 0.9rem 0 0;
    font-size: 0.78rem;
    color: var(--text-dim);
  }
  .post-foot {
    margin-top: 3rem;
    padding-top: 1.3rem;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
  }
</style>
